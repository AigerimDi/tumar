{
  "name": "family",
  "private": true,
  "version": "0.1.0",
  "description": "Tumar Family - Electron desktop companion. Local LLM (Qwen3-1.7B via @qvac/sdk) answers portfolio questions in Russian, fully offline after model load. Private deposit decryption via Cloak viewing keys.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:dmg": "electron-vite build && electron-builder --mac --arm64",
    "typecheck": "tsc --noEmit",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "@cloak.dev/sdk": "^0.1.5",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@qvac/infer-base": "^0.4.0",
    "@qvac/sdk": "^0.9.1",
    "@solana/web3.js": "^1.95.3",
    "b4a": "^1.8.0",
    "bare-abort-controller": "^1.1.1",
    "bare-buffer": "^3.6.0",
    "bare-crypto": "^1.13.4",
    "bare-events": "^2.8.2",
    "bare-fetch": "^2.8.2",
    "bare-fs": "^4.7.1",
    "bare-net": "^2.3.1",
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.4.1",
    "bare-rpc": "^1.2.0",
    "bare-runtime": "^1.28.4",
    "bare-stream": "^2.13.0",
    "bare-subprocess": "^6.0.0",
    "bare-url": "^2.4.2",
    "bare-zlib": "^1.3.3",
    "bs58": "^6.0.0",
    "compact-encoding": "^3.0.0",
    "corestore": "^7.9.2",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "require-asset": "^1.2.1",
    "safety-catch": "^1.0.3",
    "tar-stream": "^3.1.8",
    "which-runtime": "^1.3.2"
  },
  "build": {
    "appId": "co.bussler.tumar.family",
    "productName": "Tumar Family",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance"
    }
  },
  "devDependencies": {
    "@tumar/shared": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
