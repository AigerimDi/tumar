# ─── Solana RPC ──────────────────────────────────────────────────────────────
# Mainnet. NEXT_PUBLIC_RPC_URL is what the browser / wallet-adapter hits; leave
# unset to route through the same-origin /api/rpc proxy (recommended, hides
# your Helius/QuickNode key). SOLANA_RPC_UPSTREAM is what the proxy + server
# routes (/api/stats, /api/vault/.../contributions) forward to.
NEXT_PUBLIC_RPC_URL=
SOLANA_RPC_UPSTREAM=https://api.mainnet-beta.solana.com
# For production traffic, set SOLANA_RPC_UPSTREAM to a paid mainnet URL:
# SOLANA_RPC_UPSTREAM=https://mainnet.helius-rpc.com/?api-key=<YOUR_KEY>

# ─── Program ────────────────────────────────────────────────────────────────
# Same program ID across devnet + mainnet (the keypair at
# programs/tumar/target/deploy/tumar-keypair.json authors both). Program is
# deployed to mainnet via `solana program deploy` - see README.
NEXT_PUBLIC_PROGRAM_ID=HfCmnXggSF2tVQkCrEdPNjUTBYvvC8tgbebXES2sp24Y
NEXT_PUBLIC_APP_URL=https://tumar.app

# KZTE tenge stablecoin mint. Placeholder until KZTE launches on Solana.
NEXT_PUBLIC_KZTE_MINT=TuMarPLaCeHoLdErKZTEMint1111111111111111111

# Solana Pay merchant label (used only if we re-enable QR-based deposits).
NEXT_PUBLIC_MERCHANT_LABEL=Tumar Family Vault

# NOTE: NEXT_PUBLIC_USDC_MINT and USDC_MINT_AUTHORITY_SECRET_KEY used to exist
# for the devnet mock-USDC faucet. They're obsolete on mainnet - we use real
# Circle USDC (EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v) by default.
